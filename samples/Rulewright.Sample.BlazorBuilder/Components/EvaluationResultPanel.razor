@using Rulewright.Core

<div class="evaluation-result">
    @if (Result is null)
    {
        <p class="hint">Evaluate a fact to see fired rules and outputs.</p>
    }
    else
    {
        <p>Compilation mode: <strong>@Result.CompilationMode</strong></p>

        <h3>Fired rules (@Result.FiredRules.Count)</h3>
        @if (Result.FiredRules.Count == 0)
        {
            <p class="hint">No rules fired.</p>
        }
        else
        {
            <ul>
                @foreach (var fired in Result.FiredRules)
                {
                    <li>
                        <strong>@fired.RuleId</strong> (@fired.Branch)
                        @if (fired.Outputs.Count > 0)
                        {
                            <ul>
                                @foreach (var kv in fired.Outputs)
                                {
                                    <li><code>@kv.Key</code> = @Describe(kv.Value)</li>
                                }
                            </ul>
                        }
                    </li>
                }
            </ul>
        }

        <h3>Final outputs</h3>
        @if (Result.Outputs.Count == 0)
        {
            <p class="hint">(none)</p>
        }
        else
        {
            <ul>
                @foreach (var kv in Result.Outputs)
                {
                    <li><code>@kv.Key</code> = @Describe(kv.Value)</li>
                }
            </ul>
        }
    }
</div>

@code {
    [Parameter] public RuleEvaluationResult? Result { get; set; }

    private static string Describe(object? value) => value?.ToString() ?? "null";
}
