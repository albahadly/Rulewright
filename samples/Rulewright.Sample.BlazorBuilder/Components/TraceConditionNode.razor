@using Rulewright.Core

<ul class="trace-condition">
    <li class="@PassClass">
        @Node.Description — @(Node.Passed is null ? "short-circuited" : Node.Passed.Value ? "passed" : "failed")
        @if (Node.Children.Count > 0)
        {
            @foreach (var child in Node.Children)
            {
                <TraceConditionNode Node="child" />
            }
        }
    </li>
</ul>

@code {
    [Parameter, EditorRequired] public ConditionTraceNode Node { get; set; } = null!;

    private string PassClass => Node.Passed switch
    {
        true => "trace-passed",
        false => "trace-failed",
        null => "trace-short-circuited",
    };
}
