@using Rulewright.Core
@using Rulewright.Sample.BlazorBuilder.Drafts
@using Rulewright.Sample.BlazorBuilder.Services
@inject EngineService EngineService

<select value="@Leaf.FunctionName" @onchange="OnSelected">
    <option value="">— choose a function —</option>
    @foreach (var descriptor in EngineService.Engine.FunctionCatalog)
    {
        <option value="@descriptor.Name" title="@descriptor.Description">@descriptor.Name</option>
    }
</select>
@if (SelectedDescription is not null)
{
    <span class="hint">@SelectedDescription</span>
}

@code {
    [Parameter, EditorRequired] public LeafDraft Leaf { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private string? SelectedDescription =>
        EngineService.Engine.FunctionCatalog.FirstOrDefault(d => d.Name == Leaf.FunctionName)?.Description;

    private async Task OnSelected(ChangeEventArgs e)
    {
        Leaf.FunctionName = e.Value as string;
        await OnChanged.InvokeAsync();
    }
}
