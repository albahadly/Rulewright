@using Rulewright.Sample.BlazorBuilder.Services

<div class="raw-json-view">
    <label for="raw-json">Rule document JSON</label>
    <textarea id="raw-json" rows="16" @bind="_draft" @bind:event="oninput"></textarea>
    <div class="raw-json-actions">
        <button @onclick="Apply">Apply</button>
        <span class="hint">Edits here don't take effect until Apply is pressed.</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public RuleDocumentState DocumentState { get; set; } = null!;

    private string _draft = string.Empty;
    private string? _syncedFrom;

    protected override void OnParametersSet()
    {
        // Only reset the draft when the document changed out from under us (e.g. the example
        // picker loaded a new file) — never while the user is actively typing in this textarea.
        if (_syncedFrom != DocumentState.Json)
        {
            _draft = DocumentState.Json;
            _syncedFrom = DocumentState.Json;
        }
    }

    private void Apply()
    {
        DocumentState.SetJson(_draft);
        _syncedFrom = DocumentState.Json;
    }
}
