@using Rulewright.Sample.BlazorBuilder.Services

<div class="example-picker">
    <label for="example-select">Load example</label>
    <select id="example-select" @onchange="OnSelected">
        <option value="">— choose an example —</option>
        @foreach (var entry in _entries)
        {
            <option value="@entry.File">@entry.File</option>
        }
    </select>
    @if (_selectedDescription is not null)
    {
        <p class="example-description">@_selectedDescription</p>
    }
</div>

@code {
    [Parameter, EditorRequired] public ExampleCatalogService Examples { get; set; } = null!;
    [Parameter, EditorRequired] public RuleDocumentState DocumentState { get; set; } = null!;

    private IReadOnlyList<ExampleEntry> _entries = Array.Empty<ExampleEntry>();
    private string? _selectedDescription;

    protected override async Task OnInitializedAsync()
    {
        _entries = await Examples.GetManifestAsync();
    }

    private async Task OnSelected(ChangeEventArgs e)
    {
        var file = e.Value as string;
        if (string.IsNullOrEmpty(file))
        {
            _selectedDescription = null;
            return;
        }

        _selectedDescription = _entries.FirstOrDefault(x => x.File == file)?.Description;
        var json = await Examples.GetExampleJsonAsync(file);
        DocumentState.SetJson(json);
    }
}
