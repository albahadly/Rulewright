@using Rulewright.Core
@using Rulewright.Sample.BlazorBuilder.Drafts
@using Rulewright.Sample.BlazorBuilder.Json
@using Rulewright.Serialization

<span class="value-expr">
    <select value="@KindOf(Value)" @onchange="OnKindChanged">
        <option value="literal">literal</option>
        <option value="field">field</option>
        <option value="op">operator</option>
    </select>

    @switch (Value)
    {
        case LiteralExpressionDraft literal:
            <input placeholder="value" value="@ScalarJsonEncoder.DecodeScalarToText(literal.ValueJson)" @onchange="@(e => SetLiteral(literal, e))" />
            break;

        case FieldExpressionDraft field:
            <input placeholder="field.path" value="@field.Field" @onchange="@(e => SetField(field, e))" />
            break;

        case OperatorExpressionDraft op:
            <select value="@op.Operator" @onchange="@(e => OnOperatorChanged(op, e))">
                @foreach (var info in RuleSchemaCatalog.ExpressionOperators)
                {
                    <option value="@info.Operator">@info.JsonName</option>
                }
            </select>
            <span class="operand-list">
                @foreach (var operand in op.Operands.ToList())
                {
                    <ValueExpressionEditor @key="operand.Id" Value="operand" OnChanged="OnChanged"
                        OnReplace="@(newVal => ReplaceOperand(op, operand, newVal))"
                        OnRemove="@(CanRemoveOperand(op) ? EventCallback.Factory.Create(this, () => RemoveOperand(op, operand)) : default)" />
                }
            </span>
            @if (CanAddOperand(op))
            {
                <button @onclick="() => AddOperand(op)">+ operand</button>
            }
            break;

        case RawValueExpressionDraft raw:
            <span class="hint">unsupported:</span> <code>@RuleJsonValueWriter.ToJsonString(raw.Original, indented: false)</code>
            break;
    }

    @if (OnRemove.HasDelegate)
    {
        <button class="remove-btn" @onclick="OnRemove">×</button>
    }
</span>

@code {
    [Parameter, EditorRequired] public ValueExpressionDraft Value { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback<ValueExpressionDraft> OnReplace { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }

    private static string KindOf(ValueExpressionDraft value) => value switch
    {
        FieldExpressionDraft => "field",
        OperatorExpressionDraft => "op",
        _ => "literal",
    };

    private async Task OnKindChanged(ChangeEventArgs e)
    {
        ValueExpressionDraft replacement = (e.Value as string) switch
        {
            "field" => new FieldExpressionDraft(),
            "op" => new OperatorExpressionDraft(),
            _ => new LiteralExpressionDraft(),
        };

        if (KindOf(Value) != (e.Value as string))
        {
            await OnReplace.InvokeAsync(replacement);
            await OnChanged.InvokeAsync();
        }
    }

    private async Task SetLiteral(LiteralExpressionDraft literal, ChangeEventArgs e)
    {
        literal.ValueJson = ScalarJsonEncoder.EncodeAuto((e.Value as string) ?? string.Empty);
        await OnChanged.InvokeAsync();
    }

    private async Task SetField(FieldExpressionDraft field, ChangeEventArgs e)
    {
        field.Field = (e.Value as string) ?? string.Empty;
        await OnChanged.InvokeAsync();
    }

    private async Task OnOperatorChanged(OperatorExpressionDraft op, ChangeEventArgs e)
    {
        if (!Enum.TryParse<ExpressionOperator>(e.Value as string, out var newOp))
        {
            return;
        }

        op.Operator = newOp;
        var info = InfoFor(newOp);
        int min = info?.MinOperands ?? 2;
        while (op.Operands.Count < min)
        {
            op.Operands.Add(new LiteralExpressionDraft());
        }

        while (info?.MaxOperands is int max && op.Operands.Count > max)
        {
            op.Operands.RemoveAt(op.Operands.Count - 1);
        }

        await OnChanged.InvokeAsync();
    }

    private async Task ReplaceOperand(OperatorExpressionDraft parent, ValueExpressionDraft oldOperand, ValueExpressionDraft newOperand)
    {
        int index = parent.Operands.IndexOf(oldOperand);
        if (index >= 0)
        {
            parent.Operands[index] = newOperand;
        }

        await OnChanged.InvokeAsync();
    }

    private async Task AddOperand(OperatorExpressionDraft op)
    {
        op.Operands.Add(new LiteralExpressionDraft());
        await OnChanged.InvokeAsync();
    }

    private async Task RemoveOperand(OperatorExpressionDraft op, ValueExpressionDraft operand)
    {
        op.Operands.Remove(operand);
        await OnChanged.InvokeAsync();
    }

    private static ExpressionOperatorInfo? InfoFor(ExpressionOperator op)
        => RuleSchemaCatalog.ExpressionOperators.FirstOrDefault(i => i.Operator == op);

    private static bool CanAddOperand(OperatorExpressionDraft op)
    {
        var info = InfoFor(op.Operator);
        return info is null || info.MaxOperands is null || op.Operands.Count < info.MaxOperands;
    }

    private static bool CanRemoveOperand(OperatorExpressionDraft op)
    {
        var info = InfoFor(op.Operator);
        int min = info?.MinOperands ?? 1;
        return op.Operands.Count > min;
    }
}
