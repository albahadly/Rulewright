<div class="fact-editor">
    <label for="fact-json">Sample fact JSON</label>
    <textarea id="fact-json" rows="10" value="@FactJson" @oninput="OnInput"></textarea>
</div>

@code {
    [Parameter] public string FactJson { get; set; } = "{}";
    [Parameter] public EventCallback<string> FactJsonChanged { get; set; }

    private async Task OnInput(ChangeEventArgs e)
    {
        FactJson = e.Value as string ?? string.Empty;
        await FactJsonChanged.InvokeAsync(FactJson);
    }
}
