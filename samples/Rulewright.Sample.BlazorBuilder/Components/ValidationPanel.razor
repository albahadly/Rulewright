@using Rulewright.Sample.BlazorBuilder.Services

<div class="validation-panel">
    @if (DocumentState.ParseError is not null)
    {
        <p class="error">Invalid JSON: @DocumentState.ParseError</p>
    }
    else if (DocumentState.Validation.IsValid)
    {
        <p class="success">Document is valid.</p>
    }
    else
    {
        <ul class="error-list">
            @foreach (var error in DocumentState.Validation.Errors)
            {
                <li><code>@(error.Path.Length == 0 ? "(root)" : error.Path)</code> — @error.Message</li>
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired] public RuleDocumentState DocumentState { get; set; } = null!;
}
