@using Rulewright.Core
@using Rulewright.Sample.BlazorBuilder.Drafts
@using Rulewright.Serialization

<div class="action-editor">
    <select value="@Action.Type" @onchange="OnTypeChanged">
        @foreach (var info in RuleSchemaCatalog.ActionTypes)
        {
            <option value="@info.Name">@info.Name</option>
        }
    </select>

    <input placeholder="target" value="@Action.Target" @onchange="OnTargetChanged" />

    @if (Action.Type != RuleAction.RemoveOutputType && Action.Value is not null)
    {
        <ValueExpressionEditor Value="Action.Value" OnChanged="OnChanged"
            OnReplace="@(newVal => ReplaceValue(newVal))" />
    }

    @if (OnRemove.HasDelegate)
    {
        <button class="remove-btn" @onclick="OnRemove">Remove</button>
    }
</div>

@code {
    [Parameter, EditorRequired] public ActionDraft Action { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }

    private async Task OnTypeChanged(ChangeEventArgs e)
    {
        Action.Type = (e.Value as string) ?? RuleAction.SetOutputType;
        if (Action.Type == RuleAction.RemoveOutputType)
        {
            Action.Value = null;
        }
        else
        {
            Action.Value ??= new LiteralExpressionDraft();
        }

        await OnChanged.InvokeAsync();
    }

    private async Task OnTargetChanged(ChangeEventArgs e)
    {
        Action.Target = (e.Value as string) ?? string.Empty;
        await OnChanged.InvokeAsync();
    }

    private async Task ReplaceValue(ValueExpressionDraft newValue)
    {
        Action.Value = newValue;
        await OnChanged.InvokeAsync();
    }
}
