@using Rulewright.Sample.BlazorBuilder.Drafts

<div class="action-list">
    @if (Actions.Count == 0)
    {
        <p class="hint">(no actions)</p>
    }
    else
    {
        @foreach (var action in Actions.ToList())
        {
            <ActionEditor @key="action.Id" Action="action" OnChanged="OnChanged" OnRemove="@(() => Remove(action))" />
        }
    }
    <button @onclick="Add">+ Action</button>
</div>

@code {
    [Parameter, EditorRequired] public List<ActionDraft> Actions { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private async Task Add()
    {
        Actions.Add(new ActionDraft());
        await OnChanged.InvokeAsync();
    }

    private async Task Remove(ActionDraft action)
    {
        Actions.Remove(action);
        await OnChanged.InvokeAsync();
    }
}
