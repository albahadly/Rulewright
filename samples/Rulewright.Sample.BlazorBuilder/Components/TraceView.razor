@using Rulewright.Core

<div class="trace-view">
    @if (Trace is not null)
    {
        <h3>Trace</h3>
        <ul>
            @foreach (var rule in Trace.Rules)
            {
                <li>
                    <strong>@rule.RuleId</strong>:
                    @(rule.Skipped ? "skipped (disabled)" : rule.Fired ? "fired" : "did not fire")
                    @if (rule.Condition is not null)
                    {
                        <TraceConditionNode Node="rule.Condition" />
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter] public EvaluationTrace? Trace { get; set; }
}
