{
  "name": "Discount rules",
  "rules": [
    {
      "id": "vip-or-high-value",
      "description": "VIP or high-value adult customers get 10% off.",
      "priority": 10,
      "condition": {
        "type": "group",
        "operator": "AND",
        "rules": [
          { "field": "Customer.Age", "operator": "GreaterThan", "value": 18 },
          {
            "type": "group",
            "operator": "OR",
            "rules": [
              { "field": "Order.Total", "operator": "GreaterThanOrEqual", "value": 100 },
              { "field": "Customer.IsVip", "operator": "Equals", "value": true }
            ]
          }
        ]
      },
      "actions": [
        { "type": "setOutput", "target": "Discount", "value": 10 },
        { "type": "setOutput", "target": "DiscountReason", "value": "VIP or high-value order" }
      ]
    },
    {
      "id": "loyalty-bonus",
      "description": "Long-time customers get an extra 5% added on top.",
      "priority": 5,
      "condition": { "field": "Customer.LoyaltyYears", "operator": "GreaterThanOrEqual", "value": 5 },
      "actions": [
        { "type": "addToOutput", "target": "Discount", "value": 5 }
      ]
    }
  ]
}
