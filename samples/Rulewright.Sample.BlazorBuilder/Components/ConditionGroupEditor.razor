@using Rulewright.Core
@using Rulewright.Sample.BlazorBuilder.Drafts
@using Rulewright.Serialization

<div class="condition-group">
    <div class="condition-group-header">
        <select value="@Group.Operator" @onchange="OnOperatorChanged">
            @foreach (var info in RuleSchemaCatalog.LogicalOperators)
            {
                <option value="@info.Operator">@info.JsonName</option>
            }
        </select>
        <span class="hint">(@Group.Children.Count child@(Group.Children.Count == 1 ? "" : "ren"))</span>
        @if (OnRemove.HasDelegate)
        {
            <button class="remove-btn" @onclick="OnRemove">Remove group</button>
        }
    </div>

    <div class="condition-group-children">
        @foreach (var child in Group.Children.ToList())
        {
            <ConditionNodeEditor @key="child.Id" Node="child" OnChanged="OnChanged" OnRemove="() => RemoveChild(child)" />
        }
    </div>

    @if (Group.Operator != LogicalOperator.Not || Group.Children.Count == 0)
    {
        <div class="condition-group-actions">
            <button @onclick="AddLeaf">+ Condition</button>
            <button @onclick="AddGroup">+ Group</button>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public GroupDraft Group { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }

    private async Task OnOperatorChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<LogicalOperator>(e.Value as string, out var op))
        {
            Group.Operator = op;
            if (op == LogicalOperator.Not && Group.Children.Count > 1)
            {
                // A NOT group takes exactly one child — keep the first, drop the rest.
                ConditionDraft first = Group.Children[0];
                Group.Children.Clear();
                Group.Children.Add(first);
            }

            await OnChanged.InvokeAsync();
        }
    }

    private async Task AddLeaf()
    {
        Group.Children.Add(new LeafDraft());
        await OnChanged.InvokeAsync();
    }

    private async Task AddGroup()
    {
        Group.Children.Add(new GroupDraft { Operator = LogicalOperator.And, Children = { new LeafDraft() } });
        await OnChanged.InvokeAsync();
    }

    private async Task RemoveChild(ConditionDraft child)
    {
        Group.Children.Remove(child);
        await OnChanged.InvokeAsync();
    }
}
