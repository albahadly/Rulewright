{
  "ruleSet": {
    "decisionTable": {
      "name": "Shipping cost",
      "id": "shipping",
      "hitPolicy": "first",
      "inputs": [
        {
          "field": "Customer.Tier",
          "operator": "Equals"
        },
        {
          "field": "Order.Total",
          "operator": "GreaterThanOrEqual"
        }
      ],
      "outputs": [
        {
          "target": "ShippingCost"
        },
        {
          "target": "ShippingTier"
        }
      ],
      "rows": [
        {
          "when": [
            "vip",
            null
          ],
          "then": [
            0,
            "free-vip"
          ]
        },
        {
          "when": [
            null,
            100
          ],
          "then": [
            0,
            "free-over-100"
          ]
        },
        {
          "when": [
            null,
            50
          ],
          "then": [
            4.95,
            "reduced"
          ]
        },
        {
          "when": [
            null,
            null
          ],
          "then": [
            9.95,
            "standard"
          ]
        }
      ]
    }
  },
  "fact": {
    "Customer": {
      "Tier": "gold"
    },
    "Order": {
      "Total": 120
    }
  },
  "expected": {
    "firedRules": [
      "shipping-1"
    ],
    "outputs": {
      "ShippingCost": 0,
      "ShippingTier": "free-over-100"
    }
  }
}