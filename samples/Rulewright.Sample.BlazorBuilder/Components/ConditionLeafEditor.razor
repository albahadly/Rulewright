@using Rulewright.Core
@using Rulewright.Sample.BlazorBuilder.Drafts
@using Rulewright.Sample.BlazorBuilder.Json
@using Rulewright.Serialization

<div class="condition-leaf">
    <input placeholder="field.path" value="@Leaf.Field" @onchange="OnFieldChanged" />

    <select value="@Leaf.Operator" @onchange="OnOperatorChanged">
        @foreach (var info in RuleSchemaCatalog.ConditionOperators)
        {
            <option value="@info.Operator">@info.JsonName</option>
        }
    </select>

    @if (SelectedInfo?.RequiresFunctionName == true)
    {
        <CustomFunctionPicker Leaf="Leaf" OnChanged="OnChanged" />
    }

    @switch (SelectedInfo?.ValueKind)
    {
        case OperatorValueKind.None:
            break;

        case OperatorValueKind.Text:
            <input placeholder="text value" value="@ScalarJsonEncoder.DecodeScalarToText(Leaf.ValueJson)"
                   @onchange="@(e => SetValue(ScalarJsonEncoder.EncodeText((e.Value as string) ?? string.Empty)))" />
            break;

        case OperatorValueKind.Array:
            <input placeholder="a, b, c" value="@ScalarJsonEncoder.DecodeArrayToCommaSeparated(Leaf.ValueJson)"
                   @onchange="@(e => SetValue(ScalarJsonEncoder.EncodeArray((e.Value as string) ?? string.Empty)))" />
            break;

        default:
            <input placeholder="value" value="@ScalarJsonEncoder.DecodeScalarToText(Leaf.ValueJson)"
                   @onchange="@(e => SetValue(ScalarJsonEncoder.EncodeAuto((e.Value as string) ?? string.Empty)))" />
            break;
    }
</div>

@code {
    [Parameter, EditorRequired] public LeafDraft Leaf { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private ConditionOperatorInfo? SelectedInfo =>
        RuleSchemaCatalog.ConditionOperators.FirstOrDefault(i => i.Operator == Leaf.Operator);

    private async Task OnFieldChanged(ChangeEventArgs e)
    {
        Leaf.Field = (e.Value as string) ?? string.Empty;
        await OnChanged.InvokeAsync();
    }

    private async Task OnOperatorChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ConditionOperator>(e.Value as string, out var op))
        {
            Leaf.Operator = op;
            var info = RuleSchemaCatalog.ConditionOperators.First(i => i.Operator == op);
            if (info.ValueKind == OperatorValueKind.None)
            {
                Leaf.ValueJson = string.Empty;
            }

            await OnChanged.InvokeAsync();
        }
    }

    private async Task SetValue(string valueJson)
    {
        Leaf.ValueJson = valueJson;
        await OnChanged.InvokeAsync();
    }
}
