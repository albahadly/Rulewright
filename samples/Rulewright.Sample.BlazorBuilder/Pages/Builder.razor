@page "/"
@using Rulewright.Core
@using Rulewright.Sample.BlazorBuilder.Services
@implements IDisposable
@inject RuleDocumentState DocumentState
@inject EngineService EngineService
@inject ExampleCatalogService Examples

<PageTitle>Rulewright Rule Builder</PageTitle>

<div class="builder-grid">
    <section class="panel">
        <h2>Document</h2>
        <ExamplePicker Examples="Examples" DocumentState="DocumentState" />
        <RawJsonView DocumentState="DocumentState" />
        <ValidationPanel DocumentState="DocumentState" />
    </section>

    <section class="panel">
        <h2>Evaluate</h2>
        <FactEditor @bind-FactJson="_factJson" @bind-FactJson:after="Evaluate" />
        <button @onclick="Evaluate" disabled="@(!CanEvaluate)">Evaluate</button>
        @if (_evaluationError is not null)
        {
            <p class="error">@_evaluationError</p>
        }
        <EvaluationResultPanel Result="_result" />
        <TraceView Trace="_result?.Trace" />
    </section>
</div>

<section class="panel condition-editor-panel">
    <h2>Condition (visual editor)</h2>
    @if (DocumentState.SupportsConditionEditor && DocumentState.Condition is not null)
    {
        <ConditionNodeEditor Node="DocumentState.Condition" OnChanged="OnConditionChanged" />
    }
    else
    {
        <p class="hint">
            The visual editor supports a single-rule document (a top-level <code>condition</code>).
            This document is a <code>rules</code> set or a <code>decisionTable</code> — edit its
            condition(s) via the raw JSON view above.
        </p>
    }
</section>

<section class="panel condition-editor-panel">
    <h2>Actions (visual editor)</h2>
    @if (DocumentState.SupportsConditionEditor && DocumentState.Actions is not null && DocumentState.ElseActions is not null)
    {
        <h3>actions (when the condition matches)</h3>
        <ActionListEditor Actions="DocumentState.Actions" OnChanged="OnActionsChanged" />

        <h3>else (when it doesn't)</h3>
        <ActionListEditor Actions="DocumentState.ElseActions" OnChanged="OnActionsChanged" />
    }
    else
    {
        <p class="hint">
            The visual editor supports a single-rule document with a well-formed <code>actions</code>
            array — edit actions via the raw JSON view above.
        </p>
    }
</section>

@code {
    private string _factJson = "{}";
    private RuleEvaluationResult? _result;
    private string? _evaluationError;

    private bool CanEvaluate => DocumentState.ParseError is null && DocumentState.Validation.IsValid;

    protected override void OnInitialized()
    {
        DocumentState.Changed += StateHasChanged;
    }

    public void Dispose()
    {
        DocumentState.Changed -= StateHasChanged;
    }

    private void Evaluate()
    {
        _evaluationError = null;
        _result = null;

        if (!CanEvaluate)
        {
            return;
        }

        try
        {
            var loaded = EngineService.Engine.LoadRuleSet(DocumentState.Json);
            var fact = ParseFact(_factJson);
            _result = EngineService.Engine.Evaluate(loaded, fact, new EvaluationOptions { EnableTrace = true });
        }
        catch (Exception ex)
        {
            _evaluationError = ex.Message;
        }
    }

    private static Dictionary<string, object?> ParseFact(string json)
        => Rulewright.Json.SystemText.SystemTextJsonFacts.ToDictionary(
            System.Text.Json.JsonDocument.Parse(json).RootElement);

    private void OnConditionChanged()
    {
        if (DocumentState.Condition is not null)
        {
            DocumentState.ReplaceCondition(DocumentState.Condition);
        }
    }

    private void OnActionsChanged()
    {
        DocumentState.CommitActions();
    }
}
