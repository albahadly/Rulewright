@using Rulewright.Sample.BlazorBuilder.Drafts
@using Rulewright.Sample.BlazorBuilder.Json

<div class="condition-node">
    @switch (Node)
    {
        case GroupDraft group:
            @* The group renders its own Remove button in its header, next to the operator —
               not here, after the whole subtree, where it would look like "remove last child". *@
            <ConditionGroupEditor Group="group" OnChanged="OnChanged" OnRemove="OnRemove" />
            break;
        case LeafDraft leaf:
            <ConditionLeafEditor Leaf="leaf" OnChanged="OnChanged" />
            @if (OnRemove.HasDelegate)
            {
                <button class="remove-btn" @onclick="OnRemove">Remove</button>
            }
            break;
        case RawConditionDraft raw:
            <div class="raw-condition">
                <p class="hint">Unsupported node — edit via the raw JSON view above.</p>
                <pre>@RuleJsonValueWriter.ToJsonString(raw.Original, indented: false)</pre>
            </div>
            @if (OnRemove.HasDelegate)
            {
                <button class="remove-btn" @onclick="OnRemove">Remove</button>
            }
            break;
    }
</div>

@code {
    [Parameter, EditorRequired] public ConditionDraft Node { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }
}
